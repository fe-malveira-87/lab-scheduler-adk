FROM python:3.12-slim

# Instalar UV
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Copiar manifesto e instalar dependências (camada cacheável)
COPY pyproject.toml ./
RUN uv sync --no-dev --no-install-project

# Copiar código fonte
COPY mcp_servers/ ./mcp_servers/
COPY shared/      ./shared/

EXPOSE 8001

CMD ["uv", "run", "python", "-m", "mcp_servers.ocr.server"]
